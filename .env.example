# ─────────────────────────────────────────────────────────────────────────────
# Fashionistar — Environment Variables Template
# Copy this file to .env.development, .env.staging, or .env.production
# and fill in the real values. NEVER commit those files to git.
# ─────────────────────────────────────────────────────────────────────────────

# App environment: development | staging | production
APP_ENV=development

# Backend API base URL
API_URL=https://api.dev.fashionistar.com

# Sentry DSN — get from sentry.io > Project > Settings > Client Keys
SENTRY_DSN=https://YOUR_KEY@oXXXXXX.ingest.sentry.io/XXXXXXX

# Google Places API Key — get from https://console.cloud.google.com/
# Enable Places API (New) in your Google Cloud Console
# Required for location search functionality
EXPO_PUBLIC_GOOGLE_PLACES_API_KEY=AIzaSyAnc9_x2rIBTI4_o2LaNDx5pqL9p_Payjo

# Feature flags
ENABLE_STORYBOOK=false
